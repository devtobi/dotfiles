# Configuration for lfs (Large File System)
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
# Required to work with bun lockfiles
[diff "lockb"]
	textconv = bun
	binary = true
[merge]
	conflictStyle = zdiff3
[core]
	pager = hunk pager