    "automation" : {
      "socketControlMode" : "automation",
      "socketPassword" : "",
      "claudeCodeIntegration" : false,
      // "claudeBinaryPath" : "",
      // "ripgrepBinaryPath" : "",
      "suppressSubagentNotifications": true,
      "cursorIntegration": false,
      "geminiIntegration": false,
      "portBase" : 9100,
      "portRange" : 10
